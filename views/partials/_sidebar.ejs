<%# _sidebar.ejs — Desktop left navigation (only renders when authenticated) %>
<aside id="sidebar" class="hidden flex-col w-60 xl:w-64 shrink-0 bg-brown-900 h-full z-50 relative grain">
  <div class="px-7 pt-10 pb-7 border-b border-white/5">
    <div class="font-display text-3xl font-bold text-cream-50 tracking-tight">Folio</div>
    <div class="text-[10px] text-amber-400 tracking-[3px] uppercase mt-1 font-semibold opacity-80">Reading Dashboard</div>
  </div>

  <nav class="flex-1 px-3 py-5 flex flex-col gap-0.5">
    <button data-view="home" onclick="State.navigate('home')"
      class="sidebar-item flex items-center gap-3 px-3.5 py-3 rounded-xl text-left w-full transition-all duration-200 text-cream-100/40 hover:text-cream-100/70 hover:bg-white/5">
      <div class="sidebar-icon w-9 h-9 rounded-lg flex items-center justify-center transition-all shrink-0">
        <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </div>
      <span class="text-sm font-medium">Home</span>
    </button>
    <button data-view="books" onclick="State.navigate('books')"
      class="sidebar-item flex items-center gap-3 px-3.5 py-3 rounded-xl text-left w-full transition-all duration-200 text-cream-100/40 hover:text-cream-100/70 hover:bg-white/5">
      <div class="sidebar-icon w-9 h-9 rounded-lg flex items-center justify-center transition-all shrink-0">
        <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
      </div>
      <span class="text-sm font-medium">Library</span>
    </button>
    <button data-view="favorites" onclick="State.navigate('favorites')"
      class="sidebar-item flex items-center gap-3 px-3.5 py-3 rounded-xl text-left w-full transition-all duration-200 text-cream-100/40 hover:text-cream-100/70 hover:bg-white/5">
      <div class="sidebar-icon w-9 h-9 rounded-lg flex items-center justify-center transition-all shrink-0">
        <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
      </div>
      <span class="text-sm font-medium">Favorites</span>
    </button>
    <button data-view="profile" onclick="State.navigate('profile')"
      class="sidebar-item flex items-center gap-3 px-3.5 py-3 rounded-xl text-left w-full transition-all duration-200 text-cream-100/40 hover:text-cream-100/70 hover:bg-white/5">
      <div class="sidebar-icon w-9 h-9 rounded-lg flex items-center justify-center transition-all shrink-0">
        <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </div>
      <span class="text-sm font-medium">Profile</span>
    </button>
  </nav>

  <%# User card — rendered with real server data %>
  <div class="px-3 pb-7">
    <div class="bg-brown-800 rounded-2xl p-3.5 flex items-center gap-3">
      <% if (user.avatar_url) { %>
        <img src="<%= user.avatar_url %>" alt="<%= user.name %>"
          class="w-10 h-10 rounded-full object-cover shrink-0 border-2 border-amber-400/30">
      <% } else { %>
        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center font-display font-bold text-brown-900 text-lg shrink-0">
          <%= (user.name || user.email || 'R')[0].toUpperCase() %>
        </div>
      <% } %>
      <div class="min-w-0">
        <p class="text-cream-50 text-sm font-semibold truncate"><%= user.name || 'Reader' %></p>
        <p class="text-cream-300/50 text-xs truncate"><%= user.email || '' %></p>
      </div>
    </div>
  </div>
</aside>
